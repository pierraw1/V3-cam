---
// Footer.astro
---

<footer class="bg-primary w-full py-10 px-6 md:px-12 text-white font-body">
    <div class="max-w-7xl mx-auto flex flex-col gap-10 md:gap-14">
        
        <!-- Séparateur Top SVG -->
        <div class="w-full flex items-center justify-center">
            <svg class="w-full h-[2px] text-white opacity-80" preserveAspectRatio="none">
                <line x1="0" y1="1" x2="100%" y2="1" stroke="currentColor" stroke-width="2" />
            </svg>
        </div>

        <div class="flex flex-row justify-between items-center w-full">
            
            <!-- Gauche: Réseaux Sociaux -->
            <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8">
                <!-- Texte visible sur PC uniquement -->
                <span class="hidden md:inline font-heading text-[1.6rem] tracking-wide">Suivez moi :</span>
                
                <!-- Logos Réseaux empilés sur mobile, côte-à-côte sur PC -->
                <div class="flex flex-col md:flex-row gap-5">
                    
                    <!-- LinkedIn Logo -->
                    <a href="https://linkedin.com" target="_blank" aria-label="Profil LinkedIn" class="hover:opacity-80 transition-all hover:scale-105">
                        <img src="/images/linkedin.png" alt="LinkedIn" class="w-10 h-10 md:w-11 md:h-11 object-contain" />
                    </a>
                    
                    <!-- Instagram Logo -->
                    <a href="https://instagram.com" target="_blank" aria-label="Profil Instagram" class="hover:opacity-80 transition-all hover:scale-105">
                        <img src="/images/instagram.png" alt="Instagram" class="w-10 h-10 md:w-11 md:h-11 object-contain" />
                    </a>
                </div>
            </div>

            <!-- Droite: Logo Footer -->
            <div>
                <img src="/images/logo-footer.png" alt="Emblème Camille Thomas" class="w-[85px] md:w-[110px] h-auto" />
            </div>

        </div>

        <!-- Copyright Centré -->
        <div class="text-center w-full">
            <p class="text-base md:text-lg font-body tracking-[0.02em]">
                © 2025 Camille Thomas — Tous droits réservés. Version 2.0.1
            </p>
        </div>
        
    </div>
</footer>
