---
import { getEntry } from 'astro:content';
const accueil = await getEntry('pages', 'accueil');
const data = accueil.data;
---

<section class="bg-white w-full py-24 px-6 md:px-12">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-14 items-stretch">
        
        <!-- Bloc 1 : Hardskills -->
        <div class="bg-soft p-10 md:p-14 shadow-lg flex flex-col h-full rounded-sm">
            <h2 class="text-4xl md:text-5xl font-heading text-accent text-center mb-16">
                Hardskills
            </h2>
            
            <div class="flex flex-col gap-10 flex-1 justify-center">
                {data.hardskills.map((skill: any) => (
                    <div class="flex flex-col gap-3">
                        <h3 class="text-2xl md:text-3xl font-heading text-accent tracking-wide">{skill.title}</h3>
                        <p class="text-gray-900 font-body text-lg md:text-xl italic">{skill.tools}</p>
                        <div class="h-[4px] w-full bg-accent mt-2 opacity-80"></div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Colonne Droite (Blocs 2 et 3) -->
        <div class="flex flex-col gap-10 md:gap-14 h-full">
            
            <!-- Bloc 2 : Softskills -->
            <div class="bg-soft p-10 shadow-lg text-center rounded-sm">
                <h2 class="text-4xl md:text-5xl font-heading text-accent mb-12">
                    Softskills
                </h2>
                <div class="flex flex-wrap justify-center gap-5">
                    {data.softskills.map((skill: string) => (
                        <div class="bg-white text-accent font-heading text-xl px-6 py-3 shadow-[2px_2px_15px_rgba(0,0,0,0.06)] shrink-0">
                            {skill}
                        </div>
                    ))}
                </div>
            </div>

            <!-- Bloc 3 : Centre d'intérêt (Carousel) -->
            <div class="bg-soft p-10 shadow-lg flex flex-col flex-1 text-center rounded-sm">
                <h2 class="text-4xl md:text-5xl font-heading text-accent mb-12">
                    Centre d'intérêt
                </h2>
                
                <!-- Carousel Intégré -->
                <div class="relative w-full relative mx-auto aspect-[4/3] bg-white p-3 shadow-[2px_2px_20px_rgba(0,0,0,0.08)] mt-auto">
                    <!-- Cadre de visualisation -->
                    <div class="relative w-full h-full overflow-hidden">
                        <!-- Piste des slides -->
                        <div id="carousel-track" class="flex w-full h-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)]">
                            {data.interets.map((slide: any) => (
                                <div class="flex-none w-full h-full relative group">
                                    <img src={slide.img} alt={`Centre d'intérêt : ${slide.text}`} class="w-full h-full object-cover" />
                                    <!-- Badge du slide -->
                                    <div class="absolute bottom-5 right-5 bg-white px-5 py-2.5 rounded-full shadow-lg flex items-center gap-3">
                                        <span class="w-3 h-3 rounded-full bg-primary"></span>
                                        <span class="font-heading text-accent text-xl">{slide.text}</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                    
                    <!-- Flèches de contrôle -->
                    <button id="btn-prev" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/2 md:-translate-x-1/3 bg-white p-3 shadow-xl hover:scale-105 transition-transform z-10 hidden md:block" aria-label="Slide Précédent">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#F78888" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6"></polyline>
                        </svg>
                    </button>
                    <!-- Gardé affiché sur mobile en absolu, mais un poil recentré -->
                    <button id="btn-prev-mob" class="absolute left-[-5%] top-1/2 -translate-y-1/2 bg-white p-2 shadow-lg z-10 md:hidden" aria-label="Slide Précédent">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F78888" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="15 18 9 12 15 6"></polyline>
                        </svg>
                    </button>

                    <button id="btn-next" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 md:translate-x-1/3 bg-white p-3 shadow-xl hover:scale-105 transition-transform z-10 hidden md:block" aria-label="Slide Suivant">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#F78888" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </button>
                    <!-- Gardé affiché sur mobile -->
                    <button id="btn-next-mob" class="absolute right-[-5%] top-1/2 -translate-y-1/2 bg-white p-2 shadow-lg z-10 md:hidden" aria-label="Slide Suivant">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F78888" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="9 18 15 12 9 6"></polyline>
                        </svg>
                    </button>
                </div>
                
            </div>

        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const track = document.getElementById('carousel-track');
        if (!track) return;
        
        const btnPrev = document.getElementById('btn-prev');
        const btnNext = document.getElementById('btn-next');
        const btnPrevMob = document.getElementById('btn-prev-mob');
        const btnNextMob = document.getElementById('btn-next-mob');
        
        let currentIndex = 0;
        const totalSlides = track.children.length;

        const updateCarousel = () => {
            track.style.transform = `translateX(-${currentIndex * 100}%)`;
        };

        const goPrev = () => {
            currentIndex = (currentIndex > 0) ? currentIndex - 1 : totalSlides - 1;
            updateCarousel();
        };

        const goNext = () => {
            currentIndex = (currentIndex < totalSlides - 1) ? currentIndex + 1 : 0;
            updateCarousel();
        };

        if (btnPrev) btnPrev.addEventListener('click', goPrev);
        if (btnNext) btnNext.addEventListener('click', goNext);
        if (btnPrevMob) btnPrevMob.addEventListener('click', goPrev);
        if (btnNextMob) btnNextMob.addEventListener('click', goNext);
    });
</script>
