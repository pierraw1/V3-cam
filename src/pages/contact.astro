---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';

const contact = await getEntry('pages', 'contact');
const data = contact.data;
---

<Layout title="Contact | Camille Thomas">
    <div class="bg-[#FFFBF8] min-h-[90vh] pt-24 pb-32">
        <section class="max-w-7xl mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
            
            <!-- Colonne Informations Gauche -->
            <div class="flex flex-col gap-10">
                <div>
                    <span class="uppercase tracking-widest text-sm text-primary mb-4 block font-bold">{data.heading}</span>
                    <h1 class="text-5xl md:text-7xl font-heading text-accent leading-tight mb-8">
                        {data.title}
                    </h1>
                    <p class="text-accent/80 font-body text-xl max-w-lg leading-relaxed whitespace-pre-line">
                        {data.description}
                    </p>
                </div>

                <div class="border-t-[2px] border-primary/20 pt-10 flex flex-col gap-6 font-body text-[1.15rem]">
                    <a href={`mailto:${data.email}`} class="text-accent hover:text-primary transition-colors flex items-center gap-4 group w-fit">
                        <span class="w-2.5 h-2.5 bg-primary rounded-full group-hover:scale-125 transition-transform"></span>
                        {data.email}
                    </a>
                    {data.linkedin && (
                        <a href={data.linkedin} target="_blank" class="text-accent hover:text-primary transition-colors flex items-center gap-4 group w-fit">
                            <span class="w-2.5 h-2.5 bg-primary rounded-full group-hover:scale-125 transition-transform"></span>
                            Mon profil LinkedIn
                        </a>
                    )}
                </div>
            </div>

            <!-- Colonne Formulaire (Droite - Formspree) -->
            <div class="bg-white p-10 md:p-14 shadow-[0_8px_30px_rgba(149,90,90,0.06)] border border-primary/10 rounded-[2px] relative mt-10 lg:mt-0">
                <!-- Décorations d'arrière-plan -->
                <div class="absolute -top-6 -right-6 w-32 h-32 bg-soft -z-10 rounded-[2px]"></div>
                <div class="absolute -bottom-6 -left-6 w-40 h-40 bg-soft -z-10 rounded-[2px]"></div>

                <h2 class="relative inline-block font-heading text-3xl text-accent mb-10 z-10 w-auto">
                    Envoyer un message
                    <span class="absolute bottom-0 left-0 w-full h-[10px] bg-soft -z-10 rounded-sm"></span>
                </h2>

                <!-- L'action pointera vers Formspree ; inutile d'avoir du JS ! -->
                <form action={`https://formspree.io/f/${data.formspreeId}`} method="POST" class="flex flex-col gap-10">
                    
                    <div class="flex flex-col">
                        <label for="name" class="font-heading text-accent/80 mb-2">Votre nom</label>
                        <input type="text" name="name" id="name" required class="bg-transparent border-b-2 border-primary/20 py-2 text-lg font-body text-accent focus:outline-none focus:border-primary transition-colors placeholder:text-accent/30" placeholder="Jane Doe" />
                    </div>

                    <div class="flex flex-col">
                        <label for="email" class="font-heading text-accent/80 mb-2">Adresse E-mail</label>
                        <input type="email" name="_replyto" id="email" required class="bg-transparent border-b-2 border-primary/20 py-2 text-lg font-body text-accent focus:outline-none focus:border-primary transition-colors placeholder:text-accent/30" placeholder="jane@exemple.com" />
                    </div>

                    <div class="flex flex-col mb-2">
                        <label for="message" class="font-heading text-accent/80 mb-2">Votre message</label>
                        <textarea name="message" id="message" rows="4" required class="bg-transparent border-b-2 border-primary/20 py-2 text-lg font-body text-accent focus:outline-none focus:border-primary transition-colors placeholder:text-accent/30 resize-none" placeholder="Bonjour Camille, je vous contacte pour..."></textarea>
                    </div>

                    <!-- Champs masqués utiles pour Formspree -->
                    <input type="hidden" name="_subject" value="Nouveau contact depuis le portfolio !" />
                    <input type="hidden" name="_language" value="fr" />
                    
                    <!-- Bouton Submit au style Projet -->
                    <button type="submit" class="self-end flex items-center justify-center gap-3 bg-primary text-white font-heading px-8 py-5 shadow-[0px_4px_12px_rgba(247,136,136,0.3)] hover:opacity-90 active:scale-95 transition-all outline outline-2 outline-white/20 mt-4 cursor-pointer">
                        <svg class="h-[20px] text-white opacity-80" width="1" viewBox="0 0 1 100" preserveAspectRatio="none">
                            <line x1="0.5" y1="0" x2="0.5" y2="100" stroke="currentColor" stroke-width="1" />
                        </svg>
                        <span class="text-[1.15rem] tracking-wide whitespace-nowrap">Envoyer</span>
                        <svg class="h-[20px] text-white opacity-80" width="1" viewBox="0 0 1 100" preserveAspectRatio="none">
                            <line x1="0.5" y1="0" x2="0.5" y2="100" stroke="currentColor" stroke-width="1" />
                        </svg>
                    </button>

                </form>
            </div>

        </section>
    </div>
</Layout>
