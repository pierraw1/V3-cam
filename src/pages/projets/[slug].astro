---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projets');
  return projects.map((project: CollectionEntry<'projets'>) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

type Props = { project: CollectionEntry<'projets'> };
const { project } = Astro.props as Props;
const data = project.data;
---

<Layout title={`${data.title} | Portfolio`}>
    <!-- Arrière-plan global -->
    <div class="bg-[#FFFBF8] min-h-screen pb-20">
        
        <!-- Section Bannière -->
        <div class="relative w-full h-[350px] md:h-[500px]">
            <img src={data.thumbnail} alt={data.title} class="w-full h-full object-cover" onerror="this.src='/images/livre.jpeg'" />
            <!-- Overlay sombre léger pour lisibilité si besoin -->
            <div class="absolute inset-0 bg-black/10 mix-blend-multiply"></div>
            
            <!-- Tag Date (En haut à droite) -->
            <div class="absolute top-6 right-6 md:top-10 md:right-10 bg-white shadow-[0_4px_15px_rgba(0,0,0,0.15)] px-4 md:px-5 py-2.5 flex items-center gap-2.5 rounded-[4px] z-10 border border-gray-50/50">
                <span class="w-3.5 h-3.5 rounded-full bg-primary shrink-0"></span>
                <span class="font-heading text-primary text-lg md:text-xl tracking-wide">{data.date.split(' ').pop()}</span>
            </div>

            <!-- Tag Titre (En bas à gauche) -->
            <div class="absolute bottom-6 left-6 md:bottom-10 md:left-10 bg-white shadow-[0_4px_15px_rgba(0,0,0,0.15)] px-5 md:px-8 py-3.5 flex items-center gap-3.5 rounded-[4px] z-10 border border-gray-50/50">
                <span class="w-4 h-4 rounded-full bg-primary shrink-0"></span>
                <span class="font-heading text-primary text-xl md:text-3xl tracking-wide">{data.title}</span>
            </div>
        </div>

        <!-- Section Outils -->
        <div class={`flex flex-wrap gap-5 px-6 md:px-12 mt-12 mb-16 ${data.tools.length <= 3 ? 'justify-start md:ml-4' : 'justify-center mx-auto'}`}>
            {data.tools.map((tool: any) => (
                <div class="w-[70px] h-[70px] md:w-[85px] md:h-[85px] border-[3px] border-primary/40 text-primary bg-white shadow-sm flex items-center justify-center font-heading font-bold text-2xl md:text-3xl rounded-[16px] transition-transform hover:scale-105" title={tool.name}>
                    <!-- Placeholder pour logo d'outil (2 premières lettres) -->
                    {tool.logoUrl ? (
                        <img src={tool.logoUrl} alt={tool.name} class="w-3/5 h-3/5 object-contain" />
                    ) : (
                        tool.name.substring(0, 2).charAt(0).toUpperCase() + tool.name.substring(1, 2).toLowerCase()
                    )}
                </div>
            ))}
        </div>

        <!-- Contenu Détail - Grille -->
        <div class="max-w-7xl mx-auto px-0 md:px-12 flex flex-col gap-12 md:gap-16">
            
            <!-- Tier 1 : Contexte + Liens -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 px-6 md:px-0">
                <!-- Contexte (2/3) -->
                <div class="md:col-span-2 bg-white rounded-[24px] p-8 md:p-12 shadow-[0_8px_30px_rgba(149,90,90,0.06)] border border-primary/10">
                    <h2 class="relative inline-block font-heading text-primary text-3xl md:text-4xl mb-10 z-10 w-auto tracking-wide">
                        Contexte
                        <!-- Surlignage couleur secondaire -->
                        <span class="absolute bottom-1 -left-1 w-[105%] h-[40%] bg-secondary -z-10 rounded-sm"></span>
                    </h2>
                    <p class="font-body text-gray-700 text-lg md:text-[1.15rem] leading-relaxed whitespace-pre-line">
                        {data.context}
                    </p>
                </div>
                
                <!-- Liens (1/3) -->
                <div class="md:col-span-1 bg-secondary rounded-[24px] p-8 md:p-12 shadow-[0_8px_30px_rgba(149,90,90,0.08)] border border-primary/15">
                    <h2 class="relative inline-block font-heading text-primary text-3xl md:text-4xl mb-10 z-10 w-auto tracking-wide">
                        Liens
                        <!-- Surlignage contrasté -->
                        <span class="absolute bottom-1 -left-1 w-[105%] h-[40%] bg-white/80 -z-10 rounded-sm"></span>
                    </h2>
                    <div class="flex flex-col gap-4 font-body text-lg">
                        {data.links.map((l: any) => (
                            <a href={l.url} class="group flex items-center gap-3 text-accent hover:text-primary transition-colors font-semibold" target="_blank" rel="noopener noreferrer">
                                <span class="w-1.5 h-1.5 bg-primary rounded-full group-hover:scale-150 transition-transform"></span>
                                <span class="underline underline-offset-4 decoration-primary/30 group-hover:decoration-primary">{l.label}</span>
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <!-- Tier 2 : Multimedia + Missions -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 flex-col-reverse md:flex-row px-6 md:px-0">
                <!-- Zone Multimedia (1/3) -->
                <div class="md:col-span-1 bg-primary rounded-[24px] p-8 flex items-center justify-center min-h-[350px] shadow-[0_8px_30px_rgba(247,136,136,0.3)] relative overflow-hidden group cursor-pointer transition-transform hover:scale-[1.02]">
                    <!-- Icône de lecture -->
                    <svg class="w-24 h-24 text-white opacity-90 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
                    </svg>
                </div>

                <!-- Missions (2/3) -->
                <div class="md:col-span-2 bg-white rounded-[24px] p-8 md:p-12 shadow-[0_8px_30px_rgba(149,90,90,0.06)] border border-primary/10">
                    <h2 class="relative inline-block font-heading text-primary text-3xl md:text-4xl mb-10 z-10 w-auto tracking-wide">
                        Missions
                        <span class="absolute bottom-1 -left-1 w-[105%] h-[40%] bg-secondary -z-10 rounded-sm"></span>
                    </h2>
                    <ul class="list-disc pl-6 marker:text-primary space-y-3.5 font-body text-gray-700 text-lg md:text-[1.15rem]">
                        {data.missions.map((m: any) => (
                            <li>{m}</li>
                        ))}
                    </ul>
                </div>
            </div>

            <!-- Tier 3 : Hard Skills + Soft Skills en scrolling horizontal -->
            <!-- On applique overflow-x-auto, snap-x (capture le defilement). Les px-6 sont appliqués ici pour que le scroll aille de bord en bord. -->
            <div class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar gap-8 md:gap-12 px-6 md:px-0 pb-12 w-full">
                
                <!-- Hard Skills -->
                <div class="snap-center shrink-0 w-[85vw] md:w-[calc(50%-1.5rem)] bg-secondary rounded-[24px] p-8 md:p-12 shadow-[0_8px_30px_rgba(149,90,90,0.08)] border border-primary/15">
                    <h2 class="relative inline-block font-heading text-primary text-3xl md:text-4xl mb-10 z-10 w-auto tracking-wide">
                        HardSkills
                        <span class="absolute bottom-1 -left-2 w-[110%] h-[45%] bg-white -z-10 rounded-sm"></span>
                    </h2>
                    <ul class="list-disc pl-6 marker:text-primary space-y-3.5 font-body text-gray-700 text-lg md:text-[1.15rem]">
                        {data.hardSkills.map((s: any) => <li>{s}</li>)}
                    </ul>
                </div>

                <!-- Soft Skills -->
                <div class="snap-center shrink-0 w-[85vw] md:w-[calc(50%-1.5rem)] bg-primary rounded-[24px] p-8 md:p-12 shadow-[0_8px_30px_rgba(247,136,136,0.3)]">
                    <h2 class="relative inline-block font-heading text-white text-3xl md:text-4xl mb-10 z-10 w-auto tracking-wide">
                        SoftSkills
                        <span class="absolute bottom-1 -left-2 w-[110%] h-[45%] bg-accent/30 -z-10 rounded-sm"></span>
                    </h2>
                    <ul class="list-disc pl-6 marker:text-white space-y-3.5 font-body text-white text-lg md:text-[1.15rem]">
                        {data.softSkills.map((s: any) => <li>{s}</li>)}
                    </ul>
                </div>
            </div>
            
            <!-- Lien de retour simple -->
            <div class="mt-4 text-center">
                <a href="/projets" class="font-heading text-primary hover:text-primary/70 text-lg tracking-wide border-b-2 border-primary/30 hover:border-primary pb-1 transition-colors">
                    &larr; Retourner aux projets
                </a>
            </div>

        </div>
    </div>
    
    <CTA />
</Layout>
